# QR decoder — shared settings for all boards

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Task watchdog
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10

# CSI camera (ESP32-P4 boards with OV5647)
CONFIG_CAMERA_OV5647=y
CONFIG_CAMERA_OV5647_MIPI_RAW10_1280x960_BINNING_45FPS=y
CONFIG_ESP_VIDEO_ENABLE_ISP_PIPELINE_CONTROLLER=y
# Allow CSI driver to allocate its internal backup buffer for DMA safety
# CONFIG_ESP_VIDEO_DISABLE_MIPI_CSI_DRIVER_BACKUP_BUFFER is not set

# Disable task WDT — camera DQBUF blocks the idle task
CONFIG_ESP_TASK_WDT_EN=n
# FreeRTOS timer task needs more stack for camera/ISP
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=4096

# QR decoder tuning
# k_quirc (fork submodule) hardcodes MAX_VERSION=25 in k_quirc.h — its version DB
# is only populated through v25 (covers 2-of-3 v15, UR animated baseline v17,
# 3-of-5 v19, BBQr-low v18; BBQr-max v27 needs the DB extended). MAX_VERSION /
# ADAPTIVE_THRESHOLD are no longer Kconfig knobs in the fork. Contrast stretch is.
# See docs/qr-scanning-performance-requirements.md and
# docs/knowledge/k-quirc-max-version-db-bound.md.
CONFIG_K_QUIRC_CONTRAST_STRETCH=y

# Decode-resolution sweep knob (0 = auto/480). Set per sweep build.
CONFIG_QR_DECODE_SQUARE=0

# CSI auto-exposure target — dial exposure back so bright laptop-screen QR
# highlights don't clip (blowout). 0 = ISP default (over-exposes screens).
CONFIG_BOARD_CSI_AE_TARGET=70

# Debug metrics
CONFIG_CAM_PIPELINE_DEBUG=y
CONFIG_CAM_PIPELINE_QR_DEBUG=y

# LVGL fonts
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_24=y

# Core dump to flash — captures crash backtraces for post-mortem analysis
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y
CONFIG_ESP_COREDUMP_CHECKSUM_CRC32=y
CONFIG_ESP_COREDUMP_CAPTURE_DRAM=y

# Boot log to flash — captures complete boot log, survives reboot
CONFIG_BOARD_LOG_TO_FLASH=y
